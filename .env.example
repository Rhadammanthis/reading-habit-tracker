# Copy to .env and fill in. Expo inlines EXPO_PUBLIC_* vars at build time.

# Supabase project (required for auth + sync)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Google Books API key (optional — the API works unauthenticated at low volume)
EXPO_PUBLIC_GOOGLE_BOOKS_API_KEY=
